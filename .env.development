# ============================================================
#   开发环境配置 — 本地调试使用
#   复制为 .env 使用: cp .env.development .env
# ============================================================

# ===== AI 模型配置 =====
LLM_PROVIDER=zhipu
ZHIPU_API_KEYS=sk-your-dev-key
DEEPSEEK_API_KEYS=
GEMINI_API_KEYS=

MAIN_CHAT_MODEL=glm-4-flash
EMBEDDING_MODEL=embedding-2

# ===== 系统配置 =====
MAX_HISTORY_LENGTH=10
MAX_RETRIES=3

# ===== 平台接口（开发环境留空即可）=====
PDD_APP_KEY=
PDD_APP_SECRET=
PDD_ACCESS_TOKEN=

# ===== 数据库 =====
DB_URL=sqlite:///./data/sqlite/pdd_ecommerce.db
CHROMA_DB_DIR=./data/chroma

# ===== 安全（开发环境使用默认值）=====
JWT_SECRET_KEY=dev-secret-key-change-in-prod
ADMIN_USERNAME=admin
ADMIN_PASSWORD=pddbot2026

# ===== 跨域（开发环境全允许）=====
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8100,http://127.0.0.1:8100

# ===== NotebookLM =====
NOTEBOOKLM_NOTEBOOK_URL=
PDD_BOT_BASE_URL=http://localhost:8100

# ===== 服务端口 =====
PORT=8100
