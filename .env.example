# ===== AI 模型配置 =====
# 可以配置多个 API Key 以实现负载均衡和提高并发上限
LLM_PROVIDER=zhipu # 可选: zhipu, deepseek, gemini, openai

# 格式：密钥1,密钥2,密钥3 （系统将自动轮询）
ZHIPU_API_KEYS=sk-key1,sk-key2,sk-key3
DEEPSEEK_API_KEYS=sk-key1
GEMINI_API_KEYS=AIzaSy...

# 指定基础大模型和向量模型(用于存入ChromaDB)
MAIN_CHAT_MODEL=glm-4-flash
EMBEDDING_MODEL=embedding-2

# ===== 系统并发与性能 =====
# 每个用户的对话历史记忆长度（最近 N 条）
MAX_HISTORY_LENGTH=10
# 遇到模型 API 错误时的最大重试次数
MAX_RETRIES=3

# ===== 平台接口配置 (预留) =====
PDD_APP_KEY=your_app_key
PDD_APP_SECRET=your_app_secret
PDD_ACCESS_TOKEN=your_access_token

# ===== 数据库配置 =====
DB_URL=sqlite:///./data/sqlite/pdd_ecommerce.db
CHROMA_DB_DIR=./data/chroma
