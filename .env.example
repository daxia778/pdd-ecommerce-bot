# ===== AI 模型配置 =====
# 可以配置多个 API Key 以实现负载均衡和提高并发上限
LLM_PROVIDER=zhipu # 可选: zhipu, deepseek, gemini, openai

# 格式：密钥1,密钥2,密钥3 （系统将自动轮询）
ZHIPU_API_KEYS=sk-key1,sk-key2,sk-key3
DEEPSEEK_API_KEYS=sk-key1
GEMINI_API_KEYS=AIzaSy...

# 指定基础大模型和向量模型(用于存入ChromaDB)
MAIN_CHAT_MODEL=glm-4-flash
EMBEDDING_MODEL=embedding-2

# ===== 系统并发与性能 =====
# 每个用户的对话历史记忆长度（最近 N 条）
MAX_HISTORY_LENGTH=10
# 遇到模型 API 错误时的最大重试次数
MAX_RETRIES=3

# ===== 平台接口配置 (预留) =====
PDD_APP_KEY=your_app_key
PDD_APP_SECRET=your_app_secret
PDD_ACCESS_TOKEN=your_access_token
# OAuth 授权回调地址（填入 Cloudflare Tunnel 或公网域名，用于 PDD 应用申请）
# 参考 docs/callback-url-setup.md 获取公网地址
PDD_WEBHOOK_CALLBACK_URL=https://your-tunnel.trycloudflare.com/api/v1/oauth/callback


# ===== 数据库配置 =====
DB_URL=sqlite:///./data/sqlite/pdd_ecommerce.db
CHROMA_DB_DIR=./data/chroma

# ===== NotebookLM 自动化配置 =====
# 首次使用需运行: python scripts/auth_notebooklm.py 完成 Google 登录授权
# 然后将目标笔记本的 URL 填入下方（打开笔记本后复制地址栏 URL）
NOTEBOOKLM_NOTEBOOK_URL=https://notebooklm.google.com/notebook/your-notebook-id-here
# 本服务的对外访问地址（用于构造 PPT 文件的下载链接）
PDD_BOT_BASE_URL=http://localhost:8100
