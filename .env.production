# ============================================================
#   生产环境配置 — 部署到服务器时使用
#   复制为 .env 使用: cp .env.production .env
#   ⚠️ 注意：所有密钥必须替换为真实值！
# ============================================================

# ===== AI 模型配置 =====
LLM_PROVIDER=zhipu
ZHIPU_API_KEYS=sk-prod-key-1,sk-prod-key-2
DEEPSEEK_API_KEYS=sk-prod-deepseek-key
GEMINI_API_KEYS=

MAIN_CHAT_MODEL=glm-4-flash
EMBEDDING_MODEL=embedding-2

# ===== 系统配置 =====
MAX_HISTORY_LENGTH=15
MAX_RETRIES=3

# ===== 平台接口（生产环境必填）=====
PDD_APP_KEY=your_real_app_key
PDD_APP_SECRET=your_real_app_secret
PDD_ACCESS_TOKEN=your_real_access_token
PDD_WEBHOOK_CALLBACK_URL=https://your-domain.com/api/v1/oauth/callback

# ===== 数据库 =====
DB_URL=sqlite:///./data/sqlite/pdd_ecommerce.db
CHROMA_DB_DIR=./data/chroma

# ===== 安全（⚠️ 生产环境必须修改！）=====
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
ADMIN_USERNAME=admin
# 使用 python scripts/generate_hash.py 生成哈希密码
ADMIN_PASSWORD_HASH=sha256:your_salt:your_hash

# ===== 跨域（限制为实际域名）=====
CORS_ORIGINS=https://your-domain.com

# ===== NotebookLM =====
NOTEBOOKLM_NOTEBOOK_URL=https://notebooklm.google.com/notebook/your-id
PDD_BOT_BASE_URL=https://your-domain.com

# ===== 服务端口 =====
PORT=8100
FRONTEND_PORT=3000
